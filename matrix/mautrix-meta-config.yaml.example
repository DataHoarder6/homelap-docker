# Generated by mautrix-meta on first run.
# Only the appservice section contains secrets that must match registration.yaml.

network:
    mode: messenger

bridge:
    command_prefix: '!meta'
    personal_filtering_spaces: true

homeserver:
    address: http://synapse:8008
    domain: jautis.lt
    software: standard
    websocket: false

appservice:
    address: http://mautrix-meta:29319
    hostname: 0.0.0.0
    port: 29319
    id: meta
    bot:
        username: metabot
        displayname: Meta bridge bot
    ephemeral_events: true
    as_token: "CHANGEME"
    hs_token: "CHANGEME"
    username_template: meta_{{.}}
